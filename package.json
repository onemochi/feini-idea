{
  "name": "feini-contract-engine",
  "productName": "菲尼合同引擎",
  "version": "1.0.18",
  "description": "Excel 智能合同生成 + Windows 系统级 OCR PDF 拆分",
  "main": "electron/main.js",
  "author": "feini",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "release": "electron-builder --win nsis portable --x64 && node scripts/release.js",
    "release:dry": "electron-builder --win nsis portable --x64 && node scripts/release.js --dry-run",
    "release:gitee": "node gitee-release.js"
  },
  "devDependencies": {
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "electron": "27.3.11",
    "electron-builder": "24.13.3",
    "form-data": "^4.0.5",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.feini.contract.engine",
    "productName": "菲尼合同引擎",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "icon.ico",
      "ceshi/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "electron/ocr/win-ocr.ps1",
        "to": "ocr/win-ocr.ps1"
      },
      {
        "from": "ceshi",
        "to": "ceshi"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "菲尼合同引擎"
    },
    "portable": {
      "artifactName": "菲尼合同引擎-便携版-${version}.exe"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://gitee.com/Sincerity2077/feini-idea/releases/download/latest/",
        "channel": "latest",
        "useMultipleRangeRequest": false
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
